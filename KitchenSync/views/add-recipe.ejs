<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KitchenSync - Add Recipe</title>

  <!-- Bootstrap 5 CSS -->
  <link 
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" 
    rel="stylesheet"
  >

  <!-- Bootstrap Icons -->
  <link 
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" 
    rel="stylesheet"
  >

  <!-- Our Custom CSS -->
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>

  <div class="page-wrapper">

    <!-- ========== HEADER ========== -->
    <div class="inner-header">
      <a href="/recipes" class="back-link">
        <i class="bi bi-arrow-left"></i> Back
      </a>
      <span></span>
      <a href="/dashboard" class="home-link">
        <i class="bi bi-house-fill"></i>
      </a>
    </div>

    <!-- ========== ADD RECIPE FORM ========== -->
    <div class="add-item-page">
      <h3>Add Recipe</h3>

      <form id="addRecipeForm" action="/add-recipe" method="POST">

        <!-- Image Preview -->
        <div class="image-placeholder" id="imagePreview">
          <i class="bi bi-image"></i>
        </div>

        <input type="hidden" name="image" id="imageUrl">

        <!-- Recipe Title -->
        <label for="recipeTitle">Recipe Name</label>
        <input 
          type="text" 
          name="title"
          class="form-control" 
          id="recipeTitle" 
          placeholder="Enter recipe name"
          required
        >

        <!-- Image URL -->
        <label for="recipeImageInput">Recipe Image URL</label>
        <input 
          type="text"
          name="imageText"
          class="form-control"
          id="recipeImageInput"
          placeholder="Paste image URL"
        >

        <!-- Ingredients -->
        <label for="ingredients">Ingredients</label>
        <textarea
          name="ingredients"
          class="form-control"
          id="ingredients"
          rows="6"
          placeholder="Enter one ingredient per line"
          style="margin-bottom: 1rem;"
        ></textarea>

        <!-- Instructions -->
        <label for="instructions">How to Cook</label>
        <textarea
          name="instructions"
          class="form-control"
          id="instructions"
          rows="8"
          placeholder="Write the cooking steps"
          style="margin-bottom: 1rem;"
        ></textarea>

        <!-- Add Recipe Button -->
        <button type="submit" class="btn-add-item">
          Add Recipe
        </button>

      </form>

    </div>
    <!-- End Add Recipe Form -->

  </div>
  <!-- End Page Wrapper -->

  <!-- Bootstrap 5 JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <!-- Image preview script -->
  <script>
    const recipeImageInput = document.getElementById("recipeImageInput");
    const imagePreview = document.getElementById("imagePreview");
    const imageUrl = document.getElementById("imageUrl");

    if (recipeImageInput && imagePreview && imageUrl) {
      recipeImageInput.addEventListener("input", function () {
        const value = this.value.trim();

        if (!value) {
          imagePreview.innerHTML = `<i class="bi bi-image"></i>`;
          imageUrl.value = "";
          return;
        }

        imagePreview.innerHTML = `
          <img 
            src="${value}" 
            alt="Recipe preview"
            style="width:100%; height:100%; object-fit:cover; border-radius:12px;"
            onerror="this.parentElement.innerHTML='<i class=&quot;bi bi-image&quot;></i>'"
          >
        `;

        imageUrl.value = value;
      });
    }
  </script>

  <!-- Our Custom JS -->
  <script src="/js/app.js"></script>

</body>
</html>